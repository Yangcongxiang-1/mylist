#!/usr/bin/env bash
# ==============================================================
# ScreenshotOCR — Linux 区域截图 → OCR → 翻译 (纯 bash 版)
#
# 用法:
#   screenshot-ocr             截图 + OCR，结果存入剪贴板
#   screenshot-ocr -t          截图 + OCR + 自动翻译结果
#   screenshot-ocr -t ja       截图 + OCR + 翻译为日文
#   screenshot-ocr -h          显示帮助
#
# 依赖: grim slurp curl jq base64 wl-copy notify-send openssl python3
#
# API 配置方式（优先级: 环境变量 > 配置文件 > 脚本内默认值）:
#   方式1: export BAIDU_API_KEY="xxx"  (写入 ~/.bashrc 永久生效)
#   方式2: 编辑 ~/.config/screenshot-ocr.conf
# ==============================================================

set -euo pipefail

# ===================== 配置区域 =====================

# API 凭证（不要修改此处，通过配置文件或环境变量设置）
# 优先级: 环境变量 > 配置文件
BAIDU_API_KEY=""
BAIDU_SECRET_KEY=""
# 翻译专用 API Key（与 OCR 分开，独立配置）
BAIDU_TRANSLATE_API_KEY=""
BAIDU_TRANSLATE_SECRET_KEY=""

# 默认翻译目标语言（auto=自动检测源语言，zh=中文，en=英文，ja=日文，ko=韩文，fr=法文 等）
TARGET_LANG="${TARGET_LANG:-zh}"

# 临时文件
TMPDIR="${TMPDIR:-/tmp}"
SCREENSHOT_FILE="${TMPDIR}/screenshot-ocr-$$.png"
OCR_RESULT="${TMPDIR}/ocr-result-$$.txt"
TRANSLATE_RESULT="${TMPDIR}/translate-result-$$.txt"
CONF_FILE="${HOME}/.config/screenshot-ocr.conf"

# ===================== 颜色输出 =====================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

info()  { echo -e "${GREEN}[INFO]${NC} $*" >&2; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }
debug() {
    if [[ -n "${DEBUG:-}" ]]; then
        echo -e "${CYAN}[DEBUG]${NC} $*" >&2
    fi
    return 0
}

# ===================== 加载配置 =====================
load_config() {
    # 保存已存在的环境变量（优先级更高）
    local _bak_baidu_key="${BAIDU_API_KEY:-}"
    local _bak_baidu_secret="${BAIDU_SECRET_KEY:-}"
    local _bak_trans_key="${BAIDU_TRANSLATE_API_KEY:-}"
    local _bak_trans_secret="${BAIDU_TRANSLATE_SECRET_KEY:-}"

    # 加载配置文件
    if [[ -f "$CONF_FILE" ]]; then
        debug "加载配置文件: $CONF_FILE"
        source "$CONF_FILE"
    fi

    # 环境变量 > 配置文件（如果环境变量已设置，覆盖配置文件中的值）
    if [[ -n "$_bak_baidu_key" ]]; then      BAIDU_API_KEY="$_bak_baidu_key"; fi
    if [[ -n "$_bak_baidu_secret" ]]; then   BAIDU_SECRET_KEY="$_bak_baidu_secret"; fi
    if [[ -n "$_bak_trans_key" ]]; then      BAIDU_TRANSLATE_API_KEY="$_bak_trans_key"; fi
    if [[ -n "$_bak_trans_secret" ]]; then   BAIDU_TRANSLATE_SECRET_KEY="$_bak_trans_secret"; fi
}

# ===================== 依赖检查 =====================
check_deps() {
    local deps=("grim" "slurp" "curl" "jq" "base64" "wl-copy" "notify-send" "openssl" "python3")
    local missing=()

    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &>/dev/null; then
            missing+=("$dep")
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        error "缺少依赖: ${missing[*]}"
        error "请安装: sudo apt install ${missing[*]}"
        exit 1
    fi

    # 检查 API 配置（排除占位符）
    if [[ -z "$BAIDU_API_KEY" || -z "$BAIDU_SECRET_KEY" ]]; then
        error "百度 OCR API 未配置!"
        echo "  请设置环境变量或在 ${CONF_FILE} 中配置:"
        echo "    export BAIDU_API_KEY=\"your_api_key\""
        echo "    export BAIDU_SECRET_KEY=\"your_secret_key\""
        echo "  申请地址: https://console.bce.baidu.com/ai/#/ai/ocr/overview/index"
        exit 1
    fi
    if echo "$BAIDU_API_KEY$BAIDU_SECRET_KEY" | grep -Eq "在此填入|请替换|<|>"; then
        error "百度 OCR API Key 包含占位符，请填入真实值!"
        echo "  请编辑 ${CONF_FILE} 填入真实的 API Key"
        exit 1
    fi
}

# ===================== 截图 =====================
detect_display() {
    if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
        echo "wayland"
    elif [[ -n "${DISPLAY:-}" ]]; then
        echo "x11"
    else
        echo "unknown"
    fi
}

take_screenshot() {
    info "请选择截图区域..."
    local display_mode
    display_mode=$(detect_display)
    debug "显示模式: ${display_mode}"

    local shot_ok=false

    case "$display_mode" in
        wayland)
            # Wayland 下优先使用 grim + slurp（原生 Wayland 截图）
            if command -v grim &>/dev/null && command -v slurp &>/dev/null; then
                local geometry
                geometry=$(slurp 2>/dev/null) || true
                if [[ -n "$geometry" ]]; then
                    if grim -g "$geometry" "$SCREENSHOT_FILE" 2>/dev/null; then
                        shot_ok=true
                    fi
                fi
            fi
            # fallback: flameshot（用 --raw 输出到 stdout 再保存，Wayland 兼容性更好）
            if ! $shot_ok && command -v flameshot &>/dev/null; then
                info "使用 flameshot 截图..."
                if flameshot gui --raw 2>/dev/null > "$SCREENSHOT_FILE"; then
                    shot_ok=true
                fi
            fi
            ;;
        x11)
            # X11 下优先使用 maim
            if command -v maim &>/dev/null; then
                if maim -s "$SCREENSHOT_FILE" 2>/dev/null; then
                    shot_ok=true
                fi
            fi
            # fallback: scrot
            if ! $shot_ok && command -v scrot &>/dev/null; then
                if scrot -s "$SCREENSHOT_FILE" 2>/dev/null; then
                    shot_ok=true
                fi
            fi
            # fallback: import (ImageMagick)
            if ! $shot_ok && command -v import &>/dev/null; then
                if import "$SCREENSHOT_FILE" 2>/dev/null; then
                    shot_ok=true
                fi
            fi
            # fallback: gnome-screenshot
            if ! $shot_ok && command -v gnome-screenshot &>/dev/null; then
                if gnome-screenshot -a -f "$SCREENSHOT_FILE" 2>/dev/null; then
                    shot_ok=true
                fi
            fi
            # fallback: flameshot（同样使用 --raw）
            if ! $shot_ok && command -v flameshot &>/dev/null; then
                info "使用 flameshot 截图..."
                if flameshot gui --raw 2>/dev/null > "$SCREENSHOT_FILE"; then
                    shot_ok=true
                fi
            fi
            ;;
    esac

    if ! $shot_ok; then
        error "截图失败或被取消"
        error "请确保已安装截图工具: sudo apt install grim slurp  (Wayland)"
        error "                              sudo apt install maim scrot (X11)"
        exit 1
    fi

    if [[ ! -s "$SCREENSHOT_FILE" ]]; then
        error "截图文件为空"
        exit 1
    fi

    local size
    size=$(stat -c%s "$SCREENSHOT_FILE" 2>/dev/null || stat -f%z "$SCREENSHOT_FILE" 2>/dev/null)
    debug "截图保存: ${SCREENSHOT_FILE} (${size} bytes)"
    info "截图完成"
}

# ===================== 百度 OCR =====================
baidu_ocr() {
    info "正在进行 OCR 文字识别..."

    # 1. 获取 access_token
    local token_url="https://aip.baidubce.com/oauth/2.0/token"
    local token_resp
    token_resp=$(curl -s "${token_url}?grant_type=client_credentials&client_id=${BAIDU_API_KEY}&client_secret=${BAIDU_SECRET_KEY}")

    local access_token
    access_token=$(echo "$token_resp" | jq -r '.access_token // empty')

    if [[ -z "$access_token" ]]; then
        local err_msg
        err_msg=$(echo "$token_resp" | jq -r '.error_description // .error // "未知错误"')
        error "获取百度 access_token 失败: ${err_msg}"
        exit 1
    fi

    debug "access_token 获取成功"

    # 2. 调用通用文字识别
    local ocr_url="https://aip.baidubce.com/rest/2.0/ocr/v1/general_basic?access_token=${access_token}"
    local filesize
    filesize=$(stat -c%s "$SCREENSHOT_FILE" 2>/dev/null)
    debug "图片大小: ${filesize} bytes"

    # base64 编码后用 curl --data-urlencode 自动做 URL 编码
    local img_b64
    img_b64=$(base64 -w0 "$SCREENSHOT_FILE")

    local ocr_resp
    ocr_resp=$(curl -s -X POST "$ocr_url" \
        --data-urlencode "image=${img_b64}")

    # 检查错误
    debug "OCR 原始响应: $(echo "$ocr_resp" | head -c 300)"
    local err_code
    err_code=$(echo "$ocr_resp" | jq -r '.error_code // empty' 2>/dev/null)
    if [[ -n "$err_code" && "$err_code" != "null" ]]; then
        local err_msg
        err_msg=$(echo "$ocr_resp" | jq -r '.error_msg // "未知错误"')
        error "OCR 识别失败 [${err_code}]: ${err_msg}"
        # 如果是图片格式问题，打印图片信息
        if [[ "$err_code" == "216201" ]]; then
            file --mime-type "$SCREENSHOT_FILE"
            echo "文件大小: $(stat -c%s "$SCREENSHOT_FILE" 2>/dev/null) bytes"
        fi
        exit 1
    fi

    # 提取文字
    echo "$ocr_resp" | jq -r '.words_result[]?.words // empty' > "$OCR_RESULT"

    local line_count
    line_count=$(wc -l < "$OCR_RESULT")

    if [[ "$line_count" -eq 0 ]]; then
        warn "OCR 未识别到文字"
        notify-send -u critical "ScreenshotOCR" "⚠️ 未识别到文字" -i dialog-warning
        exit 0
    fi

    debug "OCR 识别到 ${line_count} 行文字"
}

# ===================== 百度翻译 =====================
# 使用百度智能云机器翻译 API（与 OCR 同套认证体系）
# 文档: https://cloud.baidu.com/doc/MT/s/4kqryjku9
baidu_translate() {
    local text="$1"
    local target_lang="${2:-zh}"

    if [[ -z "$text" ]]; then
        error "翻译文本为空"
        return 1
    fi

    if [[ -z "$BAIDU_TRANSLATE_API_KEY" || -z "$BAIDU_TRANSLATE_SECRET_KEY" ]]; then
        warn "百度翻译 API Key 未配置，跳过翻译"
        info "请编辑 ${CONF_FILE} 设置:"
        echo "  BAIDU_TRANSLATE_API_KEY=\"your_translate_api_key\"" >&2
        echo "  BAIDU_TRANSLATE_SECRET_KEY=\"your_translate_secret_key\"" >&2
        echo "  申请地址: https://console.bce.baidu.com/ai/#/ai/machinetranslation/overview/index" >&2
        return 1
    fi

    info "正在翻译为 ${target_lang}..."

    # 1. 获取 access_token（使用翻译专用 API Key）
    local token_url="https://aip.baidubce.com/oauth/2.0/token"
    local token_resp
    token_resp=$(curl -s "${token_url}?grant_type=client_credentials&client_id=${BAIDU_TRANSLATE_API_KEY}&client_secret=${BAIDU_TRANSLATE_SECRET_KEY}")

    local access_token
    access_token=$(echo "$token_resp" | jq -r '.access_token // empty')
    if [[ -z "$access_token" ]]; then
        local err_msg
        err_msg=$(echo "$token_resp" | jq -r '.error_description // "获取失败"')
        warn "翻译失败，获取 access_token 失败: ${err_msg}"
        return 1
    fi

    # 2. 调用翻译 API（POST JSON）
    local trans_url="https://aip.baidubce.com/rpc/2.0/mt/texttrans/v1?access_token=${access_token}"
    local json_body
    json_body=$(python3 -c "import json,sys; print(json.dumps({'q':sys.argv[1],'from':'auto','to':sys.argv[2]}))" "$text" "$target_lang")

    local resp
    resp=$(curl -s -X POST "$trans_url" \
        -H "Content-Type: application/json;charset=utf-8" \
        -d "$json_body")

    # 3. 检查错误
    local err_code
    err_code=$(echo "$resp" | jq -r '.error_code // empty')
    if [[ -n "$err_code" && "$err_code" != "null" ]]; then
        local err_msg
        err_msg=$(echo "$resp" | jq -r '.error_msg // "未知错误"')
        warn "翻译失败 [${err_code}]: ${err_msg}"
        debug "翻译响应: $(echo "$resp" | head -c 300)"
        return 1
    fi

    # 4. 提取结果
    local translated
    translated=$(echo "$resp" | jq -r '.result.trans_result[]?.dst // empty')

    if [[ -z "$translated" ]]; then
        warn "翻译结果为空"
        return 1
    fi

    debug "翻译成功"
    echo "$translated" > "$TRANSLATE_RESULT"
    echo "$translated"
}

# ===================== 剪贴板（解决 Wayland 下 wl-copy 后台进程被清理的问题） =====================
clipboard_copy() {
    local text="$1"
    if [[ -z "$text" ]]; then
        return
    fi
    # --foreground: 不 fork 后台进程
    # & + disown: 独立于脚本生命周期
    echo -n "$text" | wl-copy --foreground 2>/dev/null &
    disown
    # 等待 wl-copy 完成注册
    sleep 0.3
}

# ===================== 显示结果 =====================
show_result() {
    local ocr_text ocr_summary
    local skip_clipboard="${1:-false}"
    ocr_text=$(cat "$OCR_RESULT")

    if [[ "$skip_clipboard" != "true" ]]; then
        # 复制 OCR 结果到剪贴板
        clipboard_copy "$ocr_text"
        debug "OCR 结果已复制到剪贴板"
    fi

    # 构建通知内容（截取前 200 字）
    ocr_summary=$(echo "$ocr_text" | head -c 200 | sed 's/[[:space:]]*$//')
    if [[ ${#ocr_text} -gt 200 ]]; then
        ocr_summary+="..."
    fi

    notify-send -t 8000 "📝 OCR 识别结果" "${ocr_summary}" -i accessory-text-editor
    if [[ "$skip_clipboard" == "true" ]]; then
        info "OCR 识别完成（翻译结果将覆盖剪贴板）"
    else
        info "OCR 结果已复制到剪贴板"
    fi
    echo ""
    echo -e "${GREEN}========== OCR 识别结果 ==========${NC}"
    echo "$ocr_text"
    echo -e "${GREEN}==================================${NC}"
}

show_translate_result() {
    local translated_text="$1"
    local ocr_text
    ocr_text=$(cat "$OCR_RESULT")

    # 复制翻译结果到剪贴板
    clipboard_copy "$translated_text"

    local t_summary
    t_summary=$(echo "$translated_text" | head -c 200 | sed 's/[[:space:]]*$//')
    if [[ ${#translated_text} -gt 200 ]]; then
        t_summary+="..."
    fi

    notify-send -t 10000 "🌐 翻译结果" "${t_summary}" -i dialog-information
    info "翻译结果已复制到剪贴板"
    echo ""
    echo -e "${YELLOW}========== 翻译结果 ==========${NC}"
    echo "$translated_text"
    echo -e "${YELLOW}==============================${NC}"
}

# ===================== 清理 =====================
cleanup() {
    rm -f "$SCREENSHOT_FILE" "$OCR_RESULT" "$TRANSLATE_RESULT" 2>/dev/null
}

# ===================== 帮助 =====================
show_help() {
    cat <<EOF
${GREEN}ScreenshotOCR — Linux 区域截图 → OCR → 翻译工具${NC}

用法:
  $(basename "$0")                截图 + OCR，结果自动复制到剪贴板
  $(basename "$0") -t [语言]      截图 + OCR + 翻译（默认: zh）
  $(basename "$0") -h             显示此帮助

示例:
  $(basename "$0")                截图并识别文字
  $(basename "$0") -t             截图 → OCR → 翻译为中文
  $(basename "$0") -t en          截图 → OCR → 翻译为英文
  $(basename "$0") -t ja          截图 → OCR → 翻译为日文

环境变量:
  BAIDU_API_KEY               百度 OCR API Key（必填）
  BAIDU_SECRET_KEY            百度 OCR Secret Key（必填）
  BAIDU_TRANSLATE_API_KEY     百度翻译 API Key（翻译功能）
  BAIDU_TRANSLATE_SECRET_KEY  百度翻译 Secret Key（翻译功能）
  TARGET_LANG                 默认翻译目标语言（默认: zh）
  DEBUG                       启用调试日志（设置任意值）

配置文件: ${CONF_FILE}

依赖: grim, slurp, curl, jq, base64, wl-copy, notify-send, openssl, python3
EOF
}

# ===================== 主流程 =====================
main() {
    # 显示帮助
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        show_help
        exit 0
    fi

    # 加载配置
    load_config

    # 检查依赖
    check_deps

    # 注册清理
    trap cleanup EXIT

    # 检查翻译参数
    local do_translate=false
    local target_lang="$TARGET_LANG"

    if [[ "${1:-}" == "-t" || "${1:-}" == "--translate" ]]; then
        do_translate=true
        shift || true
        if [[ -n "${1:-}" && ! "$1" =~ ^- ]]; then
            target_lang="$1"
        fi
    fi

    # 如果启用翻译但未配置翻译专用 Key，仅执行 OCR
    if $do_translate && [[ -z "$BAIDU_TRANSLATE_API_KEY" || -z "$BAIDU_TRANSLATE_SECRET_KEY" ]]; then
        warn "已请求翻译但翻译 API Key 未配置，将仅执行 OCR"
        warn "请编辑 ${CONF_FILE} 设置 BAIDU_TRANSLATE_API_KEY 和 BAIDU_TRANSLATE_SECRET_KEY"
        do_translate=false
    fi

    # === 1. 截图 ===
    take_screenshot

    # === 2. OCR ===
    baidu_ocr

    # === 3. 显示 OCR 结果（带 -t 时不复制到剪贴板，留给翻译结果） ===
    show_result "$do_translate"

    # === 4. 翻译（可选） ===
    if $do_translate; then
        local text
        text=$(cat "$OCR_RESULT")
        local trans_result
        trans_result=$(baidu_translate "$text" "$target_lang") || true

        if [[ -n "$trans_result" ]]; then
            show_translate_result "$trans_result"
        fi
    fi

    info "完成!"
}

main "$@"
